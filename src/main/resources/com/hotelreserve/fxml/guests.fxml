<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotelreserve.controller.GuestsController"
      spacing="14" styleClass="screen">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Guests" styleClass="screen-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Guest" onAction="#onAddGuest" styleClass="primary-button"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
        <Label text="Search by name:"/>
        <TextField fx:id="searchField" promptText="Search guests..." prefWidth="220"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Full Name" prefWidth="180"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
            <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="130"/>
            <TableColumn fx:id="idColumn" text="ID Number" prefWidth="150"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
