<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotelreserve.controller.RoomsController"
      spacing="14" styleClass="screen">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Rooms" styleClass="screen-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Room" onAction="#onAddRoom" styleClass="primary-button"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
        <Label text="Status:"/>
        <ComboBox fx:id="filterStatusCombo" prefWidth="160"/>
        <Label text="Type:"/>
        <ComboBox fx:id="filterTypeCombo" prefWidth="140"/>
        <Button text="Reset" onAction="#onResetFilters"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="numberColumn" text="Room #" prefWidth="90"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
            <TableColumn fx:id="floorColumn" text="Floor" prefWidth="70"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
            <TableColumn fx:id="rateColumn" text="Rate/Night" prefWidth="110"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="200"/>
        </columns>
    </TableView>
</VBox>
